# Motor Avaliador — variáveis de ambiente
# Copie pra .env e preencha

# === Geral ===
APP_NAME="Avaliador Farol Público"
APP_ENV=development                 # development | production
DEBUG=true                          # false em produção
SECRET_KEY=mude-isso-pra-uma-string-aleatoria-longa
SESSION_SECRET=outra-string-aleatoria-longa

# === Banco PostgreSQL ===
DATABASE_URL=postgresql+psycopg://farol:senha@db:5432/farol_avaliador

# === Redis (queue + cache) ===
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# === Anthropic Claude ===
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL_DEFAULT=claude-haiku-4-5-20251001

# === Crawler ===
CRAWLER_TIMEOUT_S=30
CRAWLER_PAGES_PER_URL_MAX=8
CRAWLER_TOTAL_PAGES_MAX=120
CRAWLER_DOWNLOAD_PDF=true
CRAWLER_USER_AGENT="Farol-Publico-Avaliador/1.0 (+https://farolpublico.com.br)"

# === Portal Locaweb (FTP onde publicamos os relatórios) ===
PORTAL_FTP_HOST=ftp.acf2.hospedagemdesites.ws
PORTAL_FTP_PORT=21
PORTAL_FTP_USER=acf2
PORTAL_FTP_PASS=
PORTAL_FTP_REMOTE_DIR=/web/farolpublico/relatorios-2026

# === Email (opcional, pra ofícios à prefeitura) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Farol Público <contato@nossailheus.org.br>"
